    <Folder>
      <name>🏨 Hotel Base</name>
      <Placemark>
        <name>🏨 Scandic Go Upplandsgatan (Hotel Base)</name>
        <description><![CDATA[<b>Hotel base del viaje</b><br/>📅 Check-in: 2 abril 2026 ~18:00<br/>📅 Check-out: 6 abril 2026 ~09:00<br/>📍 Upplandsgatan, Norrmalm, Estocolmo<br/><br/>Zona céntrica, a pie de Drottninggatan y T-Centralen.]]></description>
        <styleUrl>#style_hotel</styleUrl>
        <Point>
          <coordinates>18.0623,59.3417,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>📅 Día 1 — Jue 2 abril — Llegada + Gamla Stan</name>
      <Placemark>
        <name>1.1 🏛️ Caramella</name>
        <description><![CDATA[<b>Tienda de chuches tradicional sueca</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~18:45 — 10 min<br/>📝 Primera parada al entrar en Gamla Stan. Chuches artesanales.]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.072,59.3248,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.2 📸 Stortorget</name>
        <description><![CDATA[<b>Plaza principal de Gamla Stan</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~19:00 — 15 min<br/>📝 Hilera de casas coloridas icónicas. Luz de atardecer ideal para fotos.<br/>🌅 Sunset: 19:34]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.0711,59.3253,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.3 ⛪ Catedral de San Nicolás</name>
        <description><![CDATA[<b>Storkyrkan — Catedral gótica de ladrillo</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~19:15 — 15 min<br/>📝 Catedral más antigua de Estocolmo. Estatua de San Jorge y el Dragón.]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.0714,59.3256,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.4 👑 Palacio Real (exterior)</name>
        <description><![CDATA[<b>Kungliga Slottet — Palacio Real de Suecia</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~19:30 — 15 min<br/>📝 Exterior al atardecer. El cambio de guardia es los sábados a las 12:15.<br/>🔗 <a href='https://www.kungligaslotten.se/english/royal-palace.html'>Web oficial</a>]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.0706,59.3267,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.5 🏛️ Riksdag (Parlamento)</name>
        <description><![CDATA[<b>Parlamento sueco — exterior</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~19:45 — 10 min<br/>📝 Edificio en isla propia entre Gamla Stan y Norrmalm. Bonito desde el puente.]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.0655,59.3271,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.6 🚶 Skeppsbron</name>
        <description><![CDATA[<b>Paseo marítimo de Gamla Stan</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~20:00 — 20 min<br/>📝 Paseo junto al agua con vistas a Djurgården y Skeppsholmen.]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.0741,59.3243,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.7 🛍️ Drottninggatan</name>
        <description><![CDATA[<b>Calle principal peatonal</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~20:30 — 15 min<br/>📝 Camino de vuelta al hotel. Tiendas, ambiente nocturno.]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.063,59.334,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>1.8 🔷 Sergels Torg</name>
        <description><![CDATA[<b>Plaza Sergel — obelisco de cristal</b><br/>📅 Día 1 — Jueves 2 abril<br/>🕐 ~20:45 — 10 min<br/>📝 Plaza icónica iluminada por la noche. Centro neurálgico de la ciudad.]]></description>
        <styleUrl>#style_dia1</styleUrl>
        <Point>
          <coordinates>18.0632,59.3328,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>📅 Día 2 — Vie 3 abril — Vaxholm + Östermalm + Moderna</name>
      <Placemark>
        <name>2.1 ⛴️ Strömkajen (embarque ferry)</name>
        <description><![CDATA[<b>Puerto de salida ferry a Vaxholm</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~09:15 — embarque 09:30<br/>📝 Ferry línea 83 (Waxholmsbolaget). Incluido en billete SL. Trayecto ~1h.<br/>App recomendada: 'Res i Sthlm' para horarios en tiempo real.<br/>🔗 <a href='https://waxholmsbolaget.se/in-english'>Waxholmsbolaget</a>]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0742,59.3308,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.2 🏝️ Vaxholm</name>
        <description><![CDATA[<b>Isla del archipiélago — excursión de medio día</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~10:30–13:00 — 2.5h<br/>📝 Pueblo pesquero con casitas de madera de colores, fortaleza, puerto.<br/>Pasear, comer algo local, disfrutar del ambiente marítimo.<br/>Ferry de vuelta ~13:00 → llegada Strömkajen ~14:00.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.3567,59.4024,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.3 🚶 Strandvägen</name>
        <description><![CDATA[<b>Paseo elegante junto al agua</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~14:15 — 30 min<br/>📝 Boulevard señorial con barcos amarrados. Empieza justo donde llega el ferry.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0831,59.3326,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.4 🎭 Dramaten (fachada)</name>
        <description><![CDATA[<b>Teatro Real Dramático — fachada Art Nouveau</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~14:45 — 10 min<br/>📝 Al final de Strandvägen. Fachada impresionante.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0738,59.3322,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.5 🌸 Kungsträdgården</name>
        <description><![CDATA[<b>Parque con cerezos en flor (abril)</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~15:00 — 25 min<br/>📝 En abril los cerezos japoneses florecen. Uno de los momentos más bonitos del año.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0719,59.3315,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.6 🌳 Humlegården</name>
        <description><![CDATA[<b>Parque tranquilo en Östermalm</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~15:30 — 20 min<br/>📝 Parque con estatua de Linneo. Zona residencial elegante.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.074,59.3372,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.7 🛍️ Biblioteksgatan</name>
        <description><![CDATA[<b>Calle de tiendas de lujo</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~16:00 — 20 min<br/>📝 Equivalente sueco de una calle comercial premium.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0725,59.3365,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.8 🍽️ Östermalm Food Hall</name>
        <description><![CDATA[<b>Mercado gastronómico desde 1880</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~16:30 — 40 min (merienda)<br/>📝 Mercado cubierto con puestos de marisco, quesos, dulces. Probar algo local.<br/>Lun-Jue 9:30-19 / Vie 9:30-20 / Sáb 9:30-18.<br/>🔗 <a href='https://ostermalmsfoodhall.se/'>Web oficial</a>]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.08,59.3352,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.9 🍬 BUBS Godis Butik</name>
        <description><![CDATA[<b>Tienda de chuches moderna</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~17:15 — 15 min<br/>📝 Chuches suecas modernas. De camino a Skeppsholmen.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0631,59.332,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.10 🏝️ Skeppsholmen</name>
        <description><![CDATA[<b>Isleta con puente de corona dorada</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 ~17:50 — 10 min<br/>📝 Puente de hierro del s.XIX con corona dorada. Vistas a Gamla Stan.]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0844,59.3266,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>2.11 🎨 Moderna Museet ⭐</name>
        <description><![CDATA[<b>Museo de arte contemporáneo — GRATIS viernes 18-20h</b><br/>📅 Día 2 — Viernes 3 abril<br/>🕐 18:00–20:00 — 2h<br/>⭐ PRIORIDAD ABSOLUTA<br/>📝 Entrada gratuita viernes de 18 a 20h (excepto exposición Picasso).<br/>¡Tirarse por el tobogán interior!<br/>🔗 <a href='https://www.modernamuseet.se/stockholm/en/'>Web oficial</a>]]></description>
        <styleUrl>#style_dia2</styleUrl>
        <Point>
          <coordinates>18.0861,59.325,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>📅 Día 3 — Sáb 4 abril — SkyView + Södermalm + Miradores</name>
      <Placemark>
        <name>3.1 🔭 SkyView (Avicii Arena) ⭐</name>
        <description><![CDATA[<b>Vistas panorámicas desde esfera de cristal</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 10:00 — 30 min<br/>⭐ OBLIGATORIO — Solo posible a las 10:00 con Fever<br/>📝 Ascensor-esfera sobre la Avicii Arena (antiguo Globen).<br/>🔗 <a href='https://skyview.ebiljett.nu/TimeBooking/ChoosenAmountOfPeople?number=4'>Reservar entradas</a>]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.0001,59.2964,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.2 🤯 Paradox Museum ⭐</name>
        <description><![CDATA[<b>Museo de ilusiones y paradojas</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~11:00 — 1h 15 min<br/>⭐ OBLIGATORIO — Con Fever<br/>📝 Museo interactivo con ilusiones ópticas, fotos divertidas.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.0613,59.3322,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.3 👑 Cambio de Guardia — Palacio Real</name>
        <description><![CDATA[<b>Cambio de guardia — Sábados 12:15</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 12:15 — 30 min<br/>📝 Ceremonia militar con banda. Llegar 10-15 min antes para buen sitio.<br/>Domingos y festivos: 13:15 en su lugar.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.0706,59.3267,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.4 🏘️ Nytorget</name>
        <description><![CDATA[<b>Callejuela con casitas — Södermalm este</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~14:00 — 45 min<br/>📝 Barrio hipster, cafeterías, tiendas vintage. Callejear sin prisa.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.0723,59.314,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.5 🏙️ Medborgarplatsen</name>
        <description><![CDATA[<b>Plaza central de Södermalm</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~14:45 — 30 min<br/>📝 Plaza animada, bares y ambiente local.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.0673,59.3145,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.6 🌿 Mariatorget</name>
        <description><![CDATA[<b>Parquecillo tranquilo en Södermalm</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~15:30 — 20 min<br/>📝 Pequeño parque con fuente. Zona residencial bonita.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.0503,59.3173,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.7 🌅 Monteliusvägen</name>
        <description><![CDATA[<b>Mirador — paseo panorámico</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~17:30 — 30 min<br/>🌅 MIRADOR ATARDECER<br/>📝 Sendero peatonal elevado con vistas espectaculares al Ayuntamiento y lago Mälaren.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.049,59.32,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.8 🌅 Skinnarviksberget</name>
        <description><![CDATA[<b>Punto natural más alto de la ciudad</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~18:15 — 45 min<br/>🌅 MEJOR MIRADOR — ATARDECER<br/>📝 El mejor mirador de Estocolmo. Roca grande donde sentarse.<br/>Llevar algo de beber para disfrutar del sunset (19:38).]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.042,59.3193,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.9 🌅 Mariaberget</name>
        <description><![CDATA[<b>Mirador — vista panorámica del otro lado</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~19:00 — 30 min<br/>🌅 Sunset: 19:38<br/>📝 Vista complementaria a Skinnarviksberget. Luz dorada.]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.047,59.321,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>3.10 🍽️ Meatballs for the People</name>
        <description><![CDATA[<b>Restaurante de albóndigas suecas</b><br/>📅 Día 3 — Sábado 4 abril<br/>🕐 ~20:00 — 1h<br/>📝 Especialidad: albóndigas suecas con diferentes salsas.<br/>⚠️ RESERVAR con antelación.<br/>🔗 <a href='https://meatball.se/'>Web oficial</a>]]></description>
        <styleUrl>#style_dia3</styleUrl>
        <Point>
          <coordinates>18.056,59.3168,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>📅 Día 4 — Dom 5 abril — Djurgården + Ayuntamiento + Spa</name>
      <Placemark>
        <name>4.1 🌿 Blå Porten (entrada Djurgården)</name>
        <description><![CDATA[<b>Puerta de entrada a Djurgården</b><br/>📅 Día 4 — Domingo 5 abril<br/>🕐 ~09:50<br/>📝 Punto de inicio del recorrido por la isla verde. Tranvía 7 desde Norrmalmstorg.]]></description>
        <styleUrl>#style_dia4</styleUrl>
        <Point>
          <coordinates>18.1025,59.3283,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>4.2 🌊 Djurgårdsbrunnsviken</name>
        <description><![CDATA[<b>Paseo por el canal de Djurgården</b><br/>📅 Día 4 — Domingo 5 abril<br/>🕐 ~10:00 — 1h<br/>📝 Canal con agua tranquila, naturaleza, cisnes. Paseo muy relajante.]]></description>
        <styleUrl>#style_dia4</styleUrl>
        <Point>
          <coordinates>18.11,59.327,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>4.3 🌹 Rosendals Trädgård</name>
        <description><![CDATA[<b>Jardín + café ecológico</b><br/>📅 Día 4 — Domingo 5 abril<br/>🕐 ~11:00 — 45 min<br/>📝 Jardín botánico con invernadero, café con pasteles caseros. Fika sueca perfecta.<br/>🔗 <a href='https://www.rosendalstradgard.se/'>Web oficial</a>]]></description>
