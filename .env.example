# Google Places API key (optional — app works without it but no Google search/details)
# Get one at https://console.cloud.google.com
VITE_GOOGLE_API_KEY=

# Firebase Realtime Database (optional — app works without it, uses localStorage only)
# Get from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
